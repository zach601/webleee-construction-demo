---
import SiteLayout from '../components/SiteLayout.astro';
import ServiceGrid from '../components/ServiceGrid.astro';

const title = 'Construction Services | ApexBuild Construction Demo';
const description = 'Explore fictional construction, renovation, roofing, project management, and maintenance services from ApexBuild Construction.';
---

<SiteLayout title={title} description={description} path="/services/">
  <section class="bg-coal">
    <div class="container-shell grid gap-10 py-20 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
      <div>
        <p class="eyebrow">Services</p>
        <h1 class="page-heading mt-4">Complete building services for serious projects.</h1>
      </div>
      <p class="body-copy max-w-2xl lg:justify-self-end">
        ApexBuild Construction is a fictional contractor brand. This service page is structured to help trade businesses explain scope, process, and value without relying on fake certifications or claims.
      </p>
    </div>
  </section>

  <section class="section-pad bg-steel">
    <div class="container-shell">
      <ServiceGrid />
    </div>
  </section>

  <section class="section-pad bg-bone text-steel">
    <div class="container-shell grid gap-8 lg:grid-cols-[0.85fr_1.15fr]">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.22em] text-rust">How Work Is Framed</p>
        <h2 class="mt-3 font-display text-3xl font-black uppercase leading-tight sm:text-4xl">Clear scope makes contractor websites feel trustworthy.</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {[
          ['Assess', 'Understand the property, timeline, constraints, and desired outcome.'],
          ['Price', 'Present a practical quote structure and clear next steps.'],
          ['Coordinate', 'Sequence trades, materials, access, safety, and communication.'],
          ['Deliver', 'Close out the work with documentation, cleanup, and handover.']
        ].map((step) => (
          <article class="border border-steel/10 bg-white p-6">
            <h3 class="text-xl font-black uppercase">{step[0]}</h3>
            <p class="mt-3 text-sm leading-6 text-steel/70">{step[1]}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-ember py-14 text-steel">
    <div class="container-shell flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
      <h2 class="max-w-3xl text-3xl font-black uppercase leading-tight">Need a contractor site that turns visits into quote requests?</h2>
      <a href="/contact/" class="inline-flex min-h-12 items-center justify-center bg-steel px-6 py-3 text-sm font-black uppercase tracking-wide text-bone transition hover:bg-bone hover:text-steel">Request a Quote</a>
    </div>
  </section>
</SiteLayout>
