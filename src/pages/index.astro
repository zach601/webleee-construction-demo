---
import SiteLayout from '../components/SiteLayout.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProjectGrid from '../components/ProjectGrid.astro';

const title = 'ApexBuild Construction | Premium Contractor Website Demo by Webleee';
const description = 'A fictional premium construction company demo website for builders, renovation companies, contractors, and trade businesses.';
---

<SiteLayout title={title} description={description}>
  <section class="relative isolate overflow-hidden bg-steel">
    <div class="absolute inset-0 -z-10">
      <img class="h-full w-full object-cover opacity-44" src="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?auto=format&fit=crop&w=1800&q=80" alt="Construction team reviewing a building site" />
      <div class="absolute inset-0 bg-[linear-gradient(90deg,#121212_0%,rgba(18,18,18,0.86)_38%,rgba(18,18,18,0.48)_100%)]"></div>
    </div>
    <div class="container-shell grid min-h-[760px] items-end gap-10 pb-10 pt-20 lg:grid-cols-[1.12fr_0.88fr]">
      <div class="max-w-4xl pb-8">
        <p class="eyebrow">Construction Website Demo</p>
        <h1 class="display-heading mt-5">Built strong. Finished sharp.</h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-bone/80">
          ApexBuild Construction is a fictional contractor brand designed to show how Webleee can present builders, renovators, and trade businesses with authority.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="/contact/" class="primary-button">Request a Quote</a>
          <a href="/projects/" class="secondary-button">View Projects</a>
        </div>
      </div>
      <div class="mb-8 grid border border-bone/15 bg-steel/80 backdrop-blur sm:grid-cols-3 lg:grid-cols-1">
        {[
          ['01', 'Planning-first project delivery'],
          ['02', 'Renovation, roofing, and fit-out services'],
          ['03', 'Fictional demo built for Webleee']
        ].map((item) => (
          <div class="border-b border-bone/10 p-5 last:border-b-0 sm:border-b-0 sm:border-r sm:last:border-r-0 lg:border-b lg:border-r-0 lg:last:border-b-0">
            <span class="text-xs font-black text-ember">{item[0]}</span>
            <p class="mt-2 text-sm font-black uppercase leading-5 text-bone">{item[1]}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-y border-bone/10 bg-coal py-8">
    <div class="container-shell grid gap-4 sm:grid-cols-3">
      {[
        ['Quality', 'Detail-focused builds and durable finishes'],
        ['Communication', 'Clear project milestones and quote visibility'],
        ['Versatility', 'Residential, commercial, and trade-ready layouts']
      ].map((item) => (
        <article class="border-l-4 border-ember bg-bone/[0.045] p-5">
          <h2 class="text-lg font-black uppercase text-bone">{item[0]}</h2>
          <p class="mt-2 text-sm leading-6 text-bone/60">{item[1]}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-pad bg-steel">
    <div class="container-shell">
      <div class="mb-10 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="eyebrow">Building Services</p>
          <h2 class="section-heading mt-3">Contractor services with a premium presentation.</h2>
        </div>
        <a href="/services/" class="secondary-button lg:mb-1">All Services</a>
      </div>
      <ServiceGrid />
    </div>
  </section>

  <section class="section-pad bg-bone text-steel">
    <div class="container-shell">
      <div class="mb-10 max-w-3xl">
        <p class="text-xs font-black uppercase tracking-[0.22em] text-rust">Featured Projects</p>
        <h2 class="mt-3 font-display text-3xl font-black uppercase leading-tight sm:text-4xl lg:text-5xl">Image-led project cards for builders and renovators.</h2>
      </div>
      <ProjectGrid />
    </div>
  </section>

  <section class="section-pad bg-coal">
    <div class="container-shell grid gap-8 lg:grid-cols-2">
      <div class="grid grid-cols-2 gap-4">
        <div class="image-panel min-h-[440px]">
          <img src="https://images.unsplash.com/photo-1590725121839-892b458a74fe?auto=format&fit=crop&w=900&q=80" alt="Older interior before renovation concept" loading="lazy" />
        </div>
        <div class="image-panel mt-12 min-h-[440px]">
          <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&w=900&q=80" alt="Finished modern home interior concept" loading="lazy" />
        </div>
      </div>
      <div class="flex flex-col justify-center">
        <p class="eyebrow">Before / After Style</p>
        <h2 class="section-heading mt-3">Show the transformation, not just the service list.</h2>
        <p class="body-copy mt-5">
          Renovation and trade websites need visual proof points. This demo uses strong project imagery, direct messaging, and quote-focused pathways for property owners and commercial clients.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <div class="industrial-card p-5">
            <p class="text-3xl font-black text-ember">Before</p>
            <p class="mt-2 text-sm leading-6 text-bone/60">Problem spaces, dated finishes, unclear scope.</p>
          </div>
          <div class="industrial-card p-5">
            <p class="text-3xl font-black text-ember">After</p>
            <p class="mt-2 text-sm leading-6 text-bone/60">Organized plans, sharp visuals, confident calls to action.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad bg-steel">
    <div class="container-shell grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="eyebrow">Why ApexBuild</p>
        <h2 class="section-heading mt-3">Made to feel dependable before the first call.</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {[
          'Bold service positioning for homeowners and commercial decision-makers.',
          'Visual project sections that help customers understand the type of work offered.',
          'Quote-focused contact paths that reduce friction on mobile and desktop.',
          'Clear fictional disclaimer and Webleee portfolio credit.'
        ].map((text) => (
          <div class="border-t-4 border-ember bg-bone/[0.045] p-6">
            <p class="text-base font-bold leading-7 text-bone/80">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-bone py-12 text-steel">
    <div class="container-shell grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-center">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.22em] text-rust">Service Areas</p>
        <h2 class="mt-3 text-3xl font-black uppercase leading-tight">Built for local trade businesses.</h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        {['Metro area', 'Suburban builds', 'Commercial districts', 'Renovation zones', 'Roofing routes', 'Maintenance calls'].map((area) => (
          <span class="border border-steel/10 bg-white px-4 py-3 text-sm font-black uppercase tracking-wide">{area}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-ember text-steel">
    <div class="container-shell flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
      <div class="max-w-3xl">
        <p class="text-xs font-black uppercase tracking-[0.22em]">Request a Quote</p>
        <h2 class="mt-3 font-display text-4xl font-black uppercase leading-none sm:text-5xl">Ready to frame the next project?</h2>
      </div>
      <a href="/contact/" class="inline-flex min-h-12 items-center justify-center bg-steel px-6 py-3 text-sm font-black uppercase tracking-wide text-bone transition hover:bg-bone hover:text-steel">Start the Quote</a>
    </div>
  </section>
</SiteLayout>
