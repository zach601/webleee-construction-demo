---
import SiteLayout from '../components/SiteLayout.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProjectGrid from '../components/ProjectGrid.astro';

const title = 'ApexBuild Construction | Premium Contractor Website Demo by Webleee';
const description = 'A fictional premium construction company demo website for builders, renovation companies, contractors, and trade businesses.';

const ledgerItems = [
  ['Project type', 'Renovations, fit-outs, roofing, repairs'],
  ['Built for', 'Homeowners, property managers, commercial operators'],
  ['Website goal', 'Turn project interest into quote requests'],
  ['Demo note', 'Fictional contractor brand created by Webleee']
];

const stages = [
  ['Measure', 'Site context, access, drawings, photos, and project constraints.'],
  ['Plan', 'Scope, sequencing, trade coordination, materials, and milestones.'],
  ['Build', 'Clean communication, durable finishes, and practical handover steps.']
];
---

<SiteLayout title={title} description={description}>
  <section class="relative isolate overflow-hidden bg-steel">
    <div class="absolute inset-0 -z-10">
      <img class="h-full w-full object-cover opacity-50" src="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?auto=format&fit=crop&w=1800&q=80" alt="Construction site with concrete and steel work in progress" />
      <div class="absolute inset-0 bg-[linear-gradient(90deg,#121212_0%,rgba(18,18,18,0.82)_42%,rgba(18,18,18,0.28)_100%)]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(0deg,#121212_0%,rgba(18,18,18,0)_45%)]"></div>
    </div>
    <div class="container-shell grid min-h-[760px] items-end gap-10 pb-10 pt-20 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="pb-8">
        <p class="eyebrow">Construction Website Sample</p>
        <h1 class="display-heading mt-5">Built work first. Quote path clear.</h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-bone/80">
          ApexBuild Construction is a fictional contractor brand designed to show a rugged, project-led website for builders, renovators, roofers, and trade businesses.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="/projects/" class="primary-button">View Built Work</a>
          <a href="/contact/" class="secondary-button">Request Quote</a>
        </div>
      </div>
      <div class="mb-8 border border-bone/15 bg-steel/88 backdrop-blur">
        <div class="border-b border-bone/10 p-5">
          <p class="text-xs font-black uppercase tracking-[0.22em] text-ember">Project ledger</p>
          <h2 class="mt-3 text-3xl font-black uppercase leading-tight text-bone">Job details before sales copy.</h2>
        </div>
        <div class="divide-y divide-bone/10">
          {ledgerItems.map(([label, value]) => (
            <div class="grid gap-2 p-5 sm:grid-cols-[0.42fr_1fr]">
              <p class="text-xs font-black uppercase tracking-wide text-sand">{label}</p>
              <p class="text-sm font-bold leading-6 text-bone">{value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad bg-bone text-steel">
    <div class="container-shell">
      <div class="mb-10 grid gap-8 lg:grid-cols-[0.72fr_1fr] lg:items-end">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.22em] text-rust">Built work</p>
          <h2 class="mt-3 font-display text-3xl font-black uppercase leading-tight sm:text-4xl lg:text-5xl">The homepage leads with projects, not abstract promises.</h2>
        </div>
        <p class="text-lg leading-8 text-steel/70">
          Contractor buyers want to see the type of work, scale, and finish quality quickly. This demo uses image-led project sections as the main trust builder.
        </p>
      </div>
      <ProjectGrid />
    </div>
  </section>

  <section class="section-pad bg-coal">
    <div class="container-shell grid gap-8 lg:grid-cols-[0.7fr_1.3fr]">
      <div>
        <p class="eyebrow">Trade blocks</p>
        <h2 class="section-heading mt-3">Services arranged like a contractor scope list.</h2>
      </div>
      <ServiceGrid />
    </div>
  </section>

  <section class="bg-steel py-16">
    <div class="container-shell grid gap-4 lg:grid-cols-3">
      {stages.map(([title, text]) => (
        <article class="relative min-h-64 border border-bone/10 bg-bone/[0.045] p-7">
          <div class="absolute right-5 top-5 h-16 w-16 border-r-4 border-t-4 border-ember"></div>
          <h2 class="text-4xl font-black uppercase text-bone">{title}</h2>
          <p class="mt-5 max-w-sm text-sm leading-7 text-bone/65">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-pad bg-coal">
    <div class="container-shell grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="grid grid-cols-2 gap-4">
        <div class="image-panel min-h-[460px]">
          <img src="https://images.unsplash.com/photo-1590725121839-892b458a74fe?auto=format&fit=crop&w=900&q=80" alt="Older interior before renovation concept" loading="eager" />
        </div>
        <div class="image-panel mt-12 min-h-[460px]">
          <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&w=900&q=80" alt="Finished modern home interior concept" loading="eager" />
        </div>
      </div>
      <div class="flex flex-col justify-center">
        <p class="eyebrow">Before / after framing</p>
        <h2 class="section-heading mt-3">Transformation belongs near the quote path.</h2>
        <p class="body-copy mt-5">
          Renovation and trade websites need more than a service list. This section gives visitors a visual reason to imagine the work, then points them toward a quote request.
        </p>
        <div class="mt-8 border border-bone/10">
          {['Problem space', 'Defined scope', 'Finished handover'].map((item, index) => (
            <div class="grid gap-4 border-b border-bone/10 p-5 last:border-b-0 sm:grid-cols-[4rem_1fr]">
              <span class="font-black text-ember">0{index + 1}</span>
              <span class="font-black uppercase text-bone">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-bone py-12 text-steel">
    <div class="container-shell grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-center">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.22em] text-rust">Service areas</p>
        <h2 class="mt-3 text-3xl font-black uppercase leading-tight">Designed for local trade businesses.</h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        {['Metro area', 'Suburban builds', 'Commercial districts', 'Renovation zones', 'Roofing routes', 'Maintenance calls'].map((area) => (
          <span class="border border-steel/10 bg-white px-4 py-3 text-sm font-black uppercase tracking-wide">{area}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-ember text-steel">
    <div class="container-shell grid gap-8 lg:grid-cols-[1fr_0.8fr] lg:items-center">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.22em]">Quote request</p>
        <h2 class="mt-3 font-display text-4xl font-black uppercase leading-none sm:text-5xl">Start with the job details.</h2>
      </div>
      <div class="bg-steel p-6 text-bone">
        <p class="text-sm leading-7 text-bone/70">The contact page is structured for scope, property type, service fit, and project details. This is demo UI for a fictional contractor brand.</p>
        <a href="/contact/" class="mt-6 inline-flex min-h-12 items-center justify-center bg-bone px-6 py-3 text-sm font-black uppercase tracking-wide text-steel transition hover:bg-sand">Request Quote</a>
      </div>
    </div>
  </section>
</SiteLayout>
